# Copy this file to .env.local and fill in the real values.
# Never commit .env.local — it's gitignored.

# ── Supabase ──
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (test mode works without Connect approval) ──
# Get sk_test_... and pk_test_... at stripe.com → Developers → API keys.
# For the webhook secret, run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# and copy the printed whsec_... value.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# When Stripe Connect is approved (live mode only):
# STRIPE_CONNECT_CLIENT_ID=
# STRIPE_IDENTITY_WEBHOOK_SECRET=

# ── Resend (transactional emails) ──
# Free test mode at resend.com. In test mode, mails only deliver to the
# email you signed up with — perfect for V1.
RESEND_API_KEY=re_...
RESEND_FROM=RideDrop <onboarding@resend.dev>

# ── Live train tracking ──
# Powers the live train tracker on a booking. Until this is set, the tracker
# runs on a realistic time-based mock. Quickest real source: Realtime Trains
# (https://api.rtt.io — free dev signup). Then wire it into
# getLiveJourneyProgress() in src/lib/darwin-api.ts.
# TRAIN_API_TOKEN=
# DARWIN_API_TOKEN=   # alternative: National Rail Darwin (OpenLDBWS)

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin / support ──
# Comma-separated list of emails that can see /admin.
# Put your founder email here (and any support staff later).
ADMIN_EMAILS=ayaan.o@outlook.com
